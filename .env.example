# Discord Webhook URL - Get this from your Discord server channel settings
# Go to Channel Settings → Integrations → Webhooks → Create Webhook
DISCORD_GITHUB_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-id/your-webhook-token

# Optional: GitHub webhook secret for signature verification
# Set this in your GitHub repository webhook settings as well
GITHUB_WEBHOOK_SECRET=your-secret-key-here